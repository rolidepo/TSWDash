              "bold": true,
              "italic": false,
              "underline": true
            },
            "unit": {
              "fontSize": "11px",
              "bold": false,
              "italic": true,
              "underline": false
            }
          }
        },
        {
            "type": "seven_segment",
            "id": "lzb_distance_display",
           
            "value": "LZB_target_speed_distance.Value",
            "area": "rpm3",
            "max":"50",
            "alignment": {
              "horizontal": "left",
              "vertical": "top"
            },
            "visible_when": {
                "variable": "LZB_IsActive.Value",
                "equals": true
            }
        },
        {
